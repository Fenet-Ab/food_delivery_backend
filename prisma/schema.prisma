// prisma/schema.prisma

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @map("_id") @default(auto()) @db.ObjectId
  name     String
  email    String @unique
  password String
  role     String @default("user")
  image    String?   // 👈 profile image URL
}

model Food {
  id          String @id @map("_id") @default(auto()) @db.ObjectId
  name        String
  description String
  price       Float
}

model Order {
  id       String @id @map("_id") @default(auto()) @db.ObjectId
  userId   String
  foodId   String
  quantity Int
  status   String @default("pending")
}